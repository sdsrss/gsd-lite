{
  "name": "gsd-lite",
  "version": "0.6.1",
  "description": "AI orchestration tool for Claude Code — GSD management shell + Superpowers quality core",
  "type": "module",
  "bin": {
    "gsd": "./cli.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:coverage": "c8 --check-coverage --lines 80 --branches 75 --reporter=text --reporter=lcov node --test tests/*.test.js",
    "lint": "biome check src/ tests/ hooks/",
    "lint:fix": "biome check --write src/ tests/ hooks/",
    "start": "node src/server.js",
    "version": "node scripts/sync-versions.js && git add .claude-plugin/plugin.json .claude-plugin/marketplace.json",
    "prepublishOnly": "node scripts/sync-versions.js && npm run lint && npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sdsrss/gsd-lite"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "orchestration",
    "ai-agent",
    "task-management"
  ],
  "files": [
    ".claude-plugin/",
    ".mcp.json",
    "src/",
    "commands/",
    "agents/",
    "workflows/",
    "references/",
    "hooks/",
    "cli.js",
    "launcher.js",
    "install.js",
    "uninstall.js",
    "package-lock.json"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "c8": "^11.0.0"
  }
}
